{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2",
            "config": {
                "includeFiles": "{app,bootstrap,config,database,public,resources,routes,storage,vendor}/**"
            }
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        { "src": "/css/(.*)", "dest": "/public/css/$1" },
        { "src": "/js/(.*)", "dest": "/public/js/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_NAME": "CodeCollab",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://code-collab-ivory-xi.vercel.app",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
        "CACHE_DRIVER": "array",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "SESSION_LIFETIME": "120",
        "LOG_CHANNEL": "stderr",
        "DB_CONNECTION": "pgsql",
        "DB_PORT": "6543",
        "DB_DATABASE": "postgres",
        "DB_SSLMODE": "require",
        "MAIL_MAILER": "smtp",
        "MAIL_HOST": "smtp.gmail.com",
        "MAIL_PORT": "587",
        "MAIL_ENCRYPTION": "tls",
        "MAIL_FROM_NAME": "CodeCollab",
        "FILESYSTEM_DISK": "local",
        "QUEUE_CONNECTION": "sync",
        "BROADCAST_CONNECTION": "log"
    }
}
